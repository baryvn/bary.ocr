# ─── Environment ──────────────────────────────────────────────────
# Môi trường chạy ứng dụng (ví dụ: dev, staging, prod)
ENV=dev
# Tên của dịch vụ, được dùng để định danh trong logs hoặc message queues
SERVICE_NAME=orc-service
# Mức độ chi tiết của log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
# Định dạng xuất log (console, json)
LOG_FORMAT=console

# ─── RabbitMQ ─────────────────────────────────────────────────────
# Host của server RabbitMQ (dùng localhost nếu chạy ngoài docker, hoặc tên container nếu trong docker)
RABBITMQ_HOST=localhost
# Cổng kết nối RabbitMQ
RABBITMQ_PORT=5672
# Tài khoản đăng nhập RabbitMQ
RABBITMQ_USER=orcadmin
# Mật khẩu đăng nhập RabbitMQ
RABBITMQ_PASSWORD=orcpassword123
# Virtual Host trong RabbitMQ để phân lập dữ liệu
RABBITMQ_VHOST=/orc

# ─── Queue Names ──────────────────────────────────────────────────
# Tên hàng đợi nhận yêu cầu OCR
QUEUE_OCR_REQUEST=ocr_request_queue
# Tên hàng đợi trả kết quả OCR
QUEUE_OCR_RESULT=ocr_result_queue
# Tên hàng đợi nhận yêu cầu bóc tách thông tin (Extraction)
QUEUE_EXTRACTION_REQUEST=extraction_request_queue
# Tên hàng đợi trả kết quả bóc tách thông tin
QUEUE_EXTRACTION_RESULT=extraction_result_queue
# Tên hàng đợi cập nhật trạng thái tiến trình
QUEUE_STATUS=status_queue

# ─── MinIO ────────────────────────────────────────────────────────
# Endpoint kết nối tới máy chủ MinIO Storage
MINIO_ENDPOINT=localhost:9000
# Access key (Tên đăng nhập) của MinIO
MINIO_ACCESS_KEY=orcminio
# Secret key (Mật khẩu) của MinIO
MINIO_SECRET_KEY=orcminiopassword123
# Tên bucket (thư mục gốc) lưu trữ toàn bộ tài liệu PDF và Markdown
MINIO_BUCKET=orc-documents
# Giao thức kết nối: false là HTTP, true là HTTPS
MINIO_SECURE=false

# ─── Redis ────────────────────────────────────────────────────────
# URL kết nối tới Redis (Định dạng: redis://:password@host:port/db_index)
REDIS_URL=redis://:orc_redis_pass@localhost:6379/0
# Thời gian sống (Time To Live) của các Job Status lưu trong Redis (Tính bằng giây, 86400 = 1 ngày)
REDIS_JOB_STATUS_TTL=86400

# ─── Oracle DB (Hệ quản trị CSDL) ─────────────────────────────────
# Data Source Name của Oracle DB
ORACLE_DSN=localhost:1521/XEPDB1
# Tên đăng nhập Oracle DB
ORACLE_USER=orc_user
# Mật khẩu Oracle DB
ORACLE_PASSWORD=orc_password
# Tiền tố cho tên bảng trong DB (VD: ORC_DOCUMENTS)
ORACLE_TABLE_PREFIX=ORC_

# ─── LLM Server (Phân loại & Bóc tách) ───────────────────────────
# URL của server chạy LLM (thường là llama.cpp đóng vai trò OpenAPI tương thích)
LLM_SERVER_URL=http://localhost:8080
# Thời gian chờ (Timeout) tính bằng giây khi gửi request tới LLM
LLM_TIMEOUT=120
# Số lần gọi lại (Retry) tối đa nếu LLM phản hồi lỗi
LLM_MAX_RETRIES=3
# Nhiệt độ (Temperature): 0.0 hoặc 0.1 để đảm bảo AI trả về kết quả chính xác, không "sáng tạo" thêm
LLM_TEMPERATURE=0.1
# Nucleus Sampling (Top-P) - Khống chế tính ngẫu nhiên của AI
LLM_TOP_P=0.9
# Hình phạt lặp từ (Repeat Penalty) - Ngăn AI lặp lại câu liên tục
LLM_REPEAT_PENALTY=1.1
# Giới hạn số lượng tokens TỐI ĐA trong KẾT QUẢ trả về của LLM
LLM_MAX_TOKENS=512
# Tổng số token Context Size (đầu vào + đầu ra) phân bổ cho Model (Cần đủ lớn để đọc hết tài liệu OCR)
LLM_CONTEXT_SIZE=8192

# ─── OCR-VL Server (Nhận dạng OCR qua Vision Model) ──────────────
# URL của server chạy mô hình OCR Vision (ví dụ PaddleOCR)
OCR_VL_SERVER_URL=http://localhost:8090
# Thời gian chờ (Timeout) tính bằng giây
OCR_VL_TIMEOUT=60
# Số lần gọi lại (Retry) tối đa nếu lỗi
OCR_VL_MAX_RETRIES=3
# Giới hạn Token tối đa để in ra kết quả OCR
OCR_VL_MAX_TOKENS=4096
# Mật độ điểm ảnh (DPI) khi render từ PDF ra ảnh gửi cho mô hình OCR (Khuyến nghị: 300)
OCR_VL_RENDER_DPI=300
# Số lượng trang (chunk) xử lý một lần để tránh tràn bộ nhớ
OCR_VL_PAGE_CHUNK_SIZE=10
# Kích thước tối đa của cạnh hình ảnh gửi lên AI (Pixel)
OCR_VL_MAX_IMAGE_PIXELS=3000

# ─── Worker Settings ─────────────────────────────────────────────
# Số lượng message mà một Worker được phép lấy (pull) về cùng lúc từ RabbitMQ
WORKER_PREFETCH_COUNT=1
# Số lần xử lý lại tối đa của Worker nếu tiến trình gặp lỗi
WORKER_MAX_RETRIES=3
# Cổng kiểm tra sức khỏe (Health check) của Worker container
WORKER_HEALTH_CHECK_PORT=8081

# ─── Model Directory (Đường dẫn Model cho Docker) ────────────────
# Thư mục chứa các file mô hình (*.gguf). Thường được map trực tiếp vào trong Docker bằng docker-compose.
# Hãy đặt các file mô hình vào đây, ví dụ:
#   - gemma-4-12b-it-qat-q4_0.gguf         (Gemma 4 dùng cho bóc tách và phân loại)
#   - PaddleOCR-VL-1.6-GGUF.gguf           (Mô hình OCR-VL)
#   - PaddleOCR-VL-1.6-GGUF-mmproj.gguf    (Mô hình Projection ảnh cho OCR-VL)
MODEL_DIR=./models
